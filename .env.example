# Get your key from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=your-cursor-api-key-here

# Optional: override the default model (discover IDs with Cursor.models.list())
# RESEARCH_MODEL=composer-2.5

# Optional but recommended for live web research (https://tavily.com/)
TAVILY_API_KEY=your-tavily-api-key-here

# Optional: protect HTTP API endpoints (Bearer token). Required in production if API is exposed.
# DEEP_RESEARCH_API_KEY=your-api-key-here

# --- Public demo (Streamlit Cloud) ---
# PUBLIC_DEMO=true
# DEMO_PASSWORD=choose-a-shared-password
# MAX_DEMO_MISSIONS_PER_DAY=10
# DEMO_SESSION_TTL_HOURS=72
# DEMO_ALLOWED_DELIVERABLES=answer
# DEMO_ALLOW_PIPELINE=false
