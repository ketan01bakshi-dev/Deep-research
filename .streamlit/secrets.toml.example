# Copy to Streamlit Cloud: Settings → Secrets
# Do not commit real keys to git.

CURSOR_API_KEY = "your-demo-cursor-api-key"
TAVILY_API_KEY = "your-demo-tavily-api-key"
PUBLIC_DEMO = "true"
DEMO_PASSWORD = "your-shared-demo-password"
MAX_DEMO_MISSIONS_PER_DAY = "10"
DEMO_SESSION_TTL_HOURS = "72"
DEMO_ALLOWED_DELIVERABLES = "answer"
DEMO_ALLOW_PIPELINE = "false"
